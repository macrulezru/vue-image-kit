{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "outDir": "./dist/cli",
    "rootDir": "./src/cli",
    "declaration": true,
    "declarationDir": "./dist/cli",
    "types": ["node"],
    "skipLibCheck": true,
    "isolatedModules": true
  },
  "include": ["src/cli/**/*.ts"]
}
